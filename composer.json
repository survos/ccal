{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.1",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "api-platform/core": "^4.0",
        "api-platform/doctrine-orm": "*",
        "api-platform/symfony": "*",
        "doctrine/annotations": "^1.0",
        "doctrine/dbal": "^3",
        "doctrine/doctrine-bundle": "^2.5",
        "doctrine/doctrine-migrations-bundle": "^3.2",
        "doctrine/orm": "^2.11",
        "dunglas/doctrine-json-odm": "^1.2",
        "friendsofsymfony/jsrouting-bundle": "^3.1",
        "gedmo/doctrine-extensions": "^3.7",
        "graceas/php-ics-reader": "^1.1",
        "johngrogg/ics-parser": "^3.1",
        "knplabs/knp-menu-bundle": "^3.2",
        "league/commonmark": "^2.2",
        "nelmio/cors-bundle": "^2.2",
        "nesbot/carbon": "^3.8",
        "phpdocumentor/reflection-docblock": "^5.6",
        "phpstan/phpdoc-parser": "^2.0",
        "spatie/icalendar-generator": "^2.6",
        "stof/doctrine-extensions-bundle": "^1.7",
        "survos/bootstrap-bundle": "^1.5",
        "symfony/asset": "^7.1",
        "symfony/asset-mapper": "^7.1",
        "symfony/config": "^7.1",
        "symfony/console": "^7.1",
        "symfony/doctrine-messenger": "^7.1",
        "symfony/dotenv": "^7.1",
        "symfony/expression-language": "^7.1",
        "symfony/flex": "^2",
        "symfony/form": "^7.1",
        "symfony/framework-bundle": "^7.1",
        "symfony/http-client": "^7.1",
        "symfony/intl": "^7.1",
        "symfony/mailer": "^7.1",
        "symfony/mime": "^7.1",
        "symfony/monolog-bundle": "^3.0",
        "symfony/notifier": "^7.1",
        "symfony/process": "^7.1",
        "symfony/property-access": "^7.1",
        "symfony/property-info": "^7.1",
        "symfony/runtime": "^7.1",
        "symfony/security-bundle": "^7.1",
        "symfony/serializer": "^7.1",
        "symfony/stimulus-bundle": "*",
        "symfony/string": "^7.1",
        "symfony/translation": "^7.1",
        "symfony/twig-bundle": "^7.1",
        "symfony/validator": "^7.1",
        "symfony/web-link": "^7.1",
        "symfony/workflow": "^7.1",
        "symfony/yaml": "^7.1",
        "tattali/calendar-bundle": "*@dev",
        "twig/extra-bundle": "^2.12|^3.0",
        "twig/markdown-extra": "^3.3",
        "twig/twig": "^2.12|^3.0"
    },
    "config": {
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "endroid/installer": true,
            "survos/installer": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "fos:js-routing:dump --format=json --target=public/js/fos_js_routes.json": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "codestyle": "vendor/bin/php-cs-fixer fix src/Controller/ --verbose --rules=@PhpCsFixer,@PSR2,@Symfony,@PHP80Migration,@PHP81Migration,modernize_strpos --allow-risky=yes --show-progress=none"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": "true",
            "require": "^7.1"
        }
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^3.4",
        "friendsofphp/php-cs-fixer": "^3.8",
        "spatie/ray": "^1.34",
        "survos/maker-bundle": "^1.5",
        "symfony/debug-bundle": "^7.1",
        "symfony/maker-bundle": "^1.38",
        "symfony/stopwatch": "^7.1",
        "symfony/web-profiler-bundle": "^7.1",
        "zenstruck/foundry": "^1.17"
    },
    "repositories": {
        "calendar": {
            "type": "path",
            "url": "/home/tac/g/tacman/CalendarBundle"
        }
    }
}
