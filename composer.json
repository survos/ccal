{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "api-platform/core": "^4.0",
        "doctrine/doctrine-bundle": "^3.0",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.6",
        "dunglas/doctrine-json-odm": "^1.4",
        "friendsofsymfony/jsrouting-bundle": "^3.5",
        "gedmo/doctrine-extensions": "^3.17",
        "johngrogg/ics-parser": "^3.5",
        "knplabs/knp-menu-bundle": "^3.5",
        "league/commonmark": "^2.4",
        "meilisearch/meilisearch-php": "^1.15",
        "nelmio/cors-bundle": "^2.5",
        "nesbot/carbon": "^3.0",
        "nyholm/psr7": "^1.8",
        "phpdocumentor/reflection-docblock": "^6.0.3",
        "spatie/icalendar-generator": "^3.0",
        "stof/doctrine-extensions-bundle": "^1.12",
        "survos/field-bundle": ">=2.6.0",
        "survos/tabler-bundle": ">=2.6.0",
        "symfony/asset": "^8.1",
        "symfony/asset-mapper": "^8.1",
        "symfony/config": "^8.1",
        "symfony/console": "^8.1",
        "symfony/doctrine-messenger": "^8.1",
        "symfony/dotenv": "^8.1",
        "symfony/expression-language": "^8.1",
        "symfony/flex": "^2",
        "symfony/form": "^8.1",
        "symfony/framework-bundle": "^8.1",
        "symfony/http-client": "^8.1",
        "symfony/intl": "^8.1",
        "symfony/mailer": "^8.1",
        "symfony/mime": "^8.1",
        "symfony/monolog-bundle": "^3.0|^4.0.2",
        "symfony/notifier": "^8.1",
        "symfony/process": "^8.1",
        "symfony/property-access": "^8.1",
        "symfony/property-info": "^8.1",
        "symfony/runtime": "^8.1",
        "symfony/security-bundle": "^8.1",
        "symfony/serializer": "^8.1",
        "symfony/stimulus-bundle": "^3.1",
        "symfony/string": "^8.1",
        "symfony/translation": "^8.1",
        "symfony/twig-bundle": "^8.1",
        "symfony/validator": "^8.1",
        "symfony/web-link": "^8.1",
        "symfony/workflow": "^8.1",
        "symfony/yaml": "^8.1",
        "twig/extra-bundle": "^3.0",
        "twig/markdown-extra": "^3.3",
        "twig/twig": "^3.0"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true,
            "php-http/discovery": true
        },
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "fos:js-routing:dump --format=json --target=public/js/fos_js_routes.json": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "codestyle": "vendor/bin/php-cs-fixer fix src/Controller/ --verbose --rules=@PhpCsFixer,@PSR2,@Symfony --allow-risky=yes --show-progress=none"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": "true",
            "require": "^8.1"
        }
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^4.0",
        "friendsofphp/php-cs-fixer": "^3.64",
        "rector/rector": "^2.0",
        "symfony/debug-bundle": "^8.1",
        "symfony/maker-bundle": "^1.60",
        "symfony/stopwatch": "^8.1",
        "symfony/web-profiler-bundle": "^8.1",
        "zenstruck/foundry": "^2.0"
    }
}
